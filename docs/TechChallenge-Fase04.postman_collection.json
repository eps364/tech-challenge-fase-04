{
  "info": {
    "_postman_id": "tech-challenge-fase-04-serverless",
    "name": "Tech Challenge Fase 04",
    "description": "Colecao de testes para a solucao serverless do Tech Challenge Fase 04. Inclui chamadas HTTP via API Gateway, invocacoes locais de Lambdas no LocalStack e consultas de apoio em DynamoDB/SQS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "API Gateway - Avaliacoes",
      "description": "Chamadas HTTP expostas pelo API Gateway. Preencha base_url com o output Terraform api_gateway_url apos o deploy em AWS.",
      "item": [
        {
          "name": "Avaliacao - Registrar critica",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descricao\": \"A aula travou varias vezes e nao consegui acompanhar o conteudo.\",\n  \"nota\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/avaliacao",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "avaliacao"
              ]
            },
            "description": "Registra feedback critico. A nota menor que 5 deve persistir a avaliacao e publicar mensagem de alerta na fila de e-mail."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Retorna id da avaliacao', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.collectionVariables.set('avaliacao_id', body.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Avaliacao - Registrar alta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descricao\": \"O conteudo foi bom, mas tive dificuldade com a dinamica da aula.\",\n  \"nota\": 6\n}"
            },
            "url": {
              "raw": "{{base_url}}/avaliacao",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "avaliacao"
              ]
            },
            "description": "Registra feedback com urgencia ALTA. Nao deve gerar alerta critico."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ]
        },
