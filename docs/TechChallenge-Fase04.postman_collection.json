        {
          "name": "Avaliacao - Erro descricao obrigatoria",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descricao\": \"\",\n  \"nota\": 7\n}"
            },
            "url": {
              "raw": "{{base_url}}/avaliacao",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "avaliacao"
              ]
            },
            "description": "Valida regra de entrada: descricao e obrigatoria."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensagem de validacao', function () {",
                  "  pm.expect(pm.response.text()).to.include('descricao is required');",
                  "});"
                ]
              }
            }
          ]
        },
