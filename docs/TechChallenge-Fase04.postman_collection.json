        {
          "name": "Avaliacao - Rota de compatibilidade",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descricao\": \"Exemplo usando a rota legada plural.\",\n  \"nota\": 8\n}"
            },
            "url": {
              "raw": "{{base_url}}/avaliacoes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "avaliacoes"
              ]
            },
            "description": "Valida a rota legada POST /avaliacoes, mantida como compatibilidade para o mesmo handler da Lambda Avaliador."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
