                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descricao\": \"Nota invalida para validar contrato.\",\n  \"nota\": 11\n}"
            },
            "url": {
              "raw": "{{base_url}}/avaliacao",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "avaliacao"
              ]
            },
            "description": "Valida regra de entrada: nota deve estar entre 0 e 10."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Mensagem de validacao', function () {",
                  "  pm.expect(pm.response.text()).to.include('nota must be between 0 and 10');",
                  "});"
                ]
              }
            }
          ]
        }
